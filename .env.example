#####################################
#DATOS GLOBALES FRAMEWORK TRASCENDER#
#####################################

#Puerto del sistema a utilizar, debe coincidir con el archivo de docker-compose
PORT:

#Host del sistema, en dev: http://ip:puerto, en prod: https://www.tudominio.com
HOST:

#Titulo del sistema, usado en title Front
TITLE:


##############################
#INTEGRACION DE OTROS SISTEMAS
##############################


#Host archivos públicos
HOST_ARCHIVOSPUBLICOS: 

#Host de cuentas, "este mismo"
HOST_ACCOUNT: 

#Sistema para gestión de analitica
#HOST_ANALYTIC: ""
#HOST_ANALYTIC_X_API_KEY: ""

#Sistema para gestión de errores
#HOST_ERROR: ""
#HOST_ERROR_X_API_KEY: ""


###############
#Autenticacion#
###############


#Llave compartida entre aplicaciones para el manejo de la sesion
SESSION_SECRET: ""

#Para produccion, dominio permitido para uso de cookie
#COOKIE_DOMAIN: ""


###############
#*****BD******#
###############


#Datos para mongodb
MONGO_URL: ""
MONGO_DBNAME: ""


#########################
#DATOS EXTRAS PRODUCCION#
#########################


#Integracion multer
FILE_UPLOAD: "1"

#Para producción, valida que sistema solo pueda ser llamado por dominios y no por ips
#ONLYDOMAIN: "1"

